<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reportingRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/report_title"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Tab selector: Missing | Extras -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/reportTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/accent"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/white"
        app:tabTextColor="@color/text_secondary" />

    <!-- Tab content area: two overlapping RecyclerViews, visibility toggled -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Missing Items tab -->
        <LinearLayout
            android:id="@+id/missingTabContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMissingItems"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="8dp" />

            <TextView
                android:id="@+id/txtMissingEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/missing_empty"
                android:textColor="@color/status_complete"
                android:textSize="18sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Extra Items tab -->
        <LinearLayout
            android:id="@+id/extraTabContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvExtraItems"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="8dp" />

            <TextView
                android:id="@+id/txtExtraEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/extra_empty"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        android:gravity="center"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToScanning"
            style="@style/Widget.ManifestSync.Button.Large"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:text="@string/btn_back_to_scanning"
            app:backgroundTint="@color/primary" />
    </LinearLayout>

</LinearLayout>
